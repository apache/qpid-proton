# AMQP 1.0 §4.4 / amqp:transactional-state:list — provisional reject finalized on commit.
declare
wait declared
fetch 1
wait fetched 1
reject
expect 1 $unsettled_in
commit
wait discharged
expect committed $last_discharge
expect 0 $unsettled_in
expect @not @empty $callback_txn_id
expect @empty $txn_id
expect @empty $error
quit
